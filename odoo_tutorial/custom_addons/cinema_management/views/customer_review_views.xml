<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_customer_review_list" model="ir.ui.view">
        <field name="name">customer.review.list</field>
        <field name="model">customer.review</field>
        <field name="arch" type="xml">
            <list string="Reviews">
                <field name="movie_id"/>
                <field name="customer_id"/>
                <field name="score"/>
                <field name="review"/>
            </list>
        </field>
    </record>

    <record id="view_customer_review_form" model="ir.ui.view">
        <field name="name">customer.review.form</field>
        <field name="model">customer.review</field>
        <field name="arch" type="xml">
            <form string="Review">
                <sheet>
                    <group>
                        <field name="movie_id"/>
                        <field name="customer_id"/>
                        <field name="score"/>
                        <field name="review"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_customer_review" model="ir.actions.act_window">
        <field name="name">Customer Reviews</field>
        <field name="res_model">customer.review</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_customer_review" name="Reviews"
              parent="menu_movie_root" action="action_customer_review" sequence="6"/>
</odoo>
