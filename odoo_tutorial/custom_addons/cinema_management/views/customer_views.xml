<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Extend Partner Form View (already done) -->
    <record id="view_partner_form_inherit_movie_theater" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.movie.theater</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="birth_date"/>
            </xpath>
        </field>
    </record>

    <!-- Action for Cinema Customers -->
    <record id="action_cinema_customers" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item under Cinema Management -->
    <menuitem id="menu_cinema_customers" name="Customers"
              parent="menu_movie_root" action="action_cinema_customers" sequence="2"/>
</odoo>
