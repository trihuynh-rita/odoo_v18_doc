<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hrm_employee_list" model="ir.ui.view">
        <field name="name">hrm.employee.list</field>
        <field name="model">hrm.employee</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_code"/>
                <field name="major"/>
                <field name="department"/>
                <field name="job_title"/>
                <field name="salary"/>
            </list>
        </field>
    </record>

    <record id="view_hrm_employee_form" model="ir.ui.view">
        <field name="name">hrm.employee.form</field>
        <field name="model">hrm.employee</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_code"/>
                            <field name="major"/>
                            <field name="department"/>
                            <field name="job_title"/>
                            <field name="hire_date"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address"/>
                            <field name="birth_date"/>
                            <field name="gender"/>
                        </group>
                    </group>

                    <group>
                        <field name="salary"/>
                    </group>

                    <notebook>
                        <page string="Work History">
                            <field name="history_work_ids" context="{'default_employee_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="status"/>
                                    <field name="date_start"/>
                                    <field name="date_end"/>
                                    <field name="award_amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hrm_employee" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hrm.employee</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
