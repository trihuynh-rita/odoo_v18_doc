<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hrm_history_work_list" model="ir.ui.view">
        <field name="name">hrm.history.work.list</field>
        <field name="model">hrm.history.work</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="status"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="award_amount"/>
            </list>
        </field>
    </record>

    <record id="view_hrm_history_work_form" model="ir.ui.view">
        <field name="name">hrm.history.work.form</field>
        <field name="model">hrm.history.work</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="status" widget="statusbar"/>
                    </group>
                    <group>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="award_amount"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hrm_history_work" model="ir.actions.act_window">
        <field name="name">Work History</field>
        <field name="res_model">hrm.history.work</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
